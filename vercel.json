{
  "buildCommand": "pnpm install --unsafe-perm && pnpm --filter ./artifacts/media-tracker run build",
  "outputDirectory": "artifacts/media-tracker/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "PORT": "4173",
    "BASE_PATH": "/"
  }
}